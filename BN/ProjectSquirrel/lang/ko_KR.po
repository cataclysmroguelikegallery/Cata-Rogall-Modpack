#: .\monsters\sq_drones.json
msgid "drone: striker MK II"
msgid_plural "drone: striker MK IIs"
msgstr[0] "드론: 타격기 MK II"

#. ~ Description for {'str': 'drone: striker MK II'}
#. ~ Description for {'str': 'inactive drone: striker MK II'}
#: .\monsters\sq_drones.json
