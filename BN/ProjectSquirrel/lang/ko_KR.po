msgid_plural "advanced nomad suit (on)s"
msgstr[0] "고급 유목민 외투 (켜짐)"

#. ~ Use action msg for {'str': 'advanced nomad suit (on)'}.
#: .\items\sq_suit.json
msgid "The %s pipes stop humming."
